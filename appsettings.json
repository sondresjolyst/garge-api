{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "None"
    },
    "Console": {
      "IncludeScopes": true,
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff ",
        "IncludeScopes": true
      }
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://www.garge.no",
      "https://garge.no",
      "https://dev.garge.no"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "*:/api/auth/login", "Period": "1m", "Limit": 10 },
      { "Endpoint": "*:/api/auth/register", "Period": "1m", "Limit": 5 },
      { "Endpoint": "*:/api/auth/refresh-token", "Period": "1m", "Limit": 20 },
      { "Endpoint": "*:/api/auth/request-password-reset", "Period": "1m", "Limit": 5 },
      { "Endpoint": "*:/api/auth/reset-password", "Period": "1m", "Limit": 5 },
      { "Endpoint": "*:/api/auth/resend-email-verification", "Period": "1m", "Limit": 1 }
    ]
  }
}
